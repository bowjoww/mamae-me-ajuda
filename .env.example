# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API Key (used for Text-to-Speech and content moderation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Upstash Redis (used for rate limiting)
# Create a free database at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase (auth + persistence)
# Create a free project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog Analytics (LGPD-compliant, privacy-first)
# Get your project API key at: https://app.posthog.com
# Leave blank to disable analytics entirely
NEXT_PUBLIC_POSTHOG_KEY=
# Default: https://app.posthog.com  Override for self-hosted PostHog instances
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry — error tracking and performance monitoring
# Create a project at: https://sentry.io  (free tier available)
# Leave blank to disable Sentry entirely
#
# Client-side DSN (safe to expose in browser bundles)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (same value as above; used by Node.js/edge runtimes)
SENTRY_DSN=
# Build-time: org and project slugs for source-map uploads in CI
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source-map uploads (generate at https://sentry.io/settings/auth-tokens/)
SENTRY_AUTH_TOKEN=
# App version / release tag (e.g. git SHA or semver) for release tracking
NEXT_PUBLIC_APP_VERSION=
